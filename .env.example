# PA Template — Environment Variables
# Set these in Railway (not in a local .env file for the container).

# ── LLM Provider ──
OLLAMA_API_KEY=
OLLAMA_BASE_URL=https://ollama.com/v1

# ── Supabase (memory layer) ──
SUPABASE_MEMORY_URL=
SUPABASE_MEMORY_KEY=

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
GATEWAY_ALLOW_ALL_USERS=false

# ── Embedding model (for Supabase semantic memory) ──
EMBED_MODEL=nomic-embed-text
EXTRACT_MODEL=gpt-oss:20b

# ── Google Calendar OAuth (base64-encoded files) ──
# GCP_OAUTH_KEYS_B64=<base64 of gcp-oauth.keys.json>
# GCAL_TOKENS_B64=<base64 of ~/.config/google-calendar-mcp/tokens.json>

# ── GitHub (optional) ──
# GITHUB_TOKEN=
# GITHUB_USER=
# GH_TOKEN=
# GIT_AUTHOR_NAME=
# GIT_AUTHOR_EMAIL=

# ── Railway build config ──
RAILWAY_DOCKERFILE_PATH=Dockerfile.railway
