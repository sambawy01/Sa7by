# Hermes-PA environment — copy to .env and fill in real values (NEVER commit .env)

# ── LLM (Ollama Cloud) ──
OLLAMA_API_KEY=***
OLLAMA_BASE_URL=https://ollama.com/v1
EMBED_MODEL=nomic-embed-text          # embeddings run locally via fastembed (nomic-embed-text-v1.5)
EXTRACT_MODEL=gpt-oss:20b             # session-end memory extraction model

# ── Fallback LLM (used when Ollama Cloud is down) ──
# If not set, the bot has no fallback and will go silent on provider outages.
OPENROUTER_API_KEY=***

# ── Supabase memory ──
SUPABASE_MEMORY_URL=https://<ref>.supabase.co
SUPABASE_MEMORY_KEY=<service_role_or_sb_secret_key>

# ── Telegram gateway ──
TELEGRAM_BOT_TOKEN=<from_@BotFather>
TELEGRAM_ALLOWED_USERS=<your_numeric_user_id>
GATEWAY_ALLOW_ALL_USERS=false

# ── GitHub (coder persona) ──
GITHUB_TOKEN=<fine_grained_pat>
GITHUB_USER=<github_username>
GIT_AUTHOR_NAME=<name>
GIT_AUTHOR_EMAIL=<email>

# ── Google Calendar MCP (Railway: base64 of the local files) ──
# GCP_OAUTH_KEYS_B64=<base64 of gcp-oauth.keys.json>
# GCAL_TOKENS_B64=<base64 of ~/.config/google-calendar-mcp/tokens.json>

# ── Backups (daily cron → Supabase Storage; defaults shown, both optional) ──
HERMES_BACKUP_BUCKET=hermes-backups
HERMES_BACKUP_KEEP=14
